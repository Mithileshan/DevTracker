# Backend
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/devtracker-x?retryWrites=true&w=majority
JWT_ACCESS_SECRET=your_jwt_access_secret_key_min_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SALT_ROUNDS=10

# Frontend
VITE_API_URL=http://localhost:5000/api
