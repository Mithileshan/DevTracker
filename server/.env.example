# Server Environment Variables
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/devtracker-x?retryWrites=true&w=majority

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_key_min_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
